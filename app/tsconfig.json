{
"compilerOptions": {
"target": "ESNext",
"lib": ["DOM", "DOM.Iterable", "ESNext"],
"module": "ESNext",
"skipLibCheck": true,
"moduleResolution": "bundler",
"allowImportingTsExtensions": true,
"resolveJsonModule": true,
"isolatedModules": true,
"noEmit": true,
"jsx": "react-jsx",
"strict": false,
"noImplicitAny": false,
"suppressImplicitAnyIndexErrors": true,
"ignoreDeprecations": "5.0",
"baseUrl": ".",
"paths": {
"@/": ["./src/"]
}
},
"include": ["src"]
}